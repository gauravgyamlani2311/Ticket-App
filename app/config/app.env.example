# ==========================================================
# DATABASE CONFIGURATION
# ==========================================================
# Use 'db' if running via Docker Compose, or 'localhost' if running PHP locally
DB_HOST=db
DB_NAME=ticket_db
DB_USER=root
DB_PASS=password
DB_PORT=3306

# ==========================================================
# APPLICATION SETTINGS
# ==========================================================
APP_NAME="TicketApp Portal"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8081

# ==========================================================
# SECURITY & API KEYS (Placeholders for assessment)
# ==========================================================
SECRET_KEY=replace_this_with_a_random_string
API_TOKEN=your_api_token_here