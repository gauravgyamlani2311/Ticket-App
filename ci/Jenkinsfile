pipeline {
    agent any

    environment {
        IMAGE_NAME = "ticket-app"
    }

    stages {
        stage('Checkout') {
            steps {
                echo '--- Fetching Code from GitHub ---'
                checkout scm
            }
        }

        stage('Validation / Lint') {
            steps {
                echo '--- Running Code Validation ---'
                sh "ls -R app/"
                // Add a basic lint check if you have one, or just verify structure
                sh "test -f app/index.html && echo 'Structure Verified'"
            }
        }

        stage('Build') {
            steps {
                echo '--- Preparing Build Environment ---'
                // This stage is for pre-compilation or env setup
                sh "printenv"
            }
        }

        stage('Docker Image Build') {
    steps {
        sh "docker build -f docker/Dockerfile -t ticket-app:latest ."
        
        // THIS MUST RUN BEFORE THE DEPLOY STAGE
        sh "minikube image load ticket-app:latest --overwrite"
    }
}

        stage('Test / Smoke Test') {
            steps {
                echo '--- Running Smoke Tests ---'
                // Verify the image exists in Docker locally
                sh "docker images | grep ${IMAGE_NAME}"
            }
        }

        stage('Deploy to Kubernetes') {
    steps {
        // This ensures we are at the root of the project workspace
        // where 'k8s' and 'ci' folders are visible as siblings.
        dir("${env.WORKSPACE}") { 
            echo '--- Deploying from k8s/base directory ---'
            
            sh "kubectl apply -f k8s/base/namespace.yaml"
            sh "kubectl apply -f k8s/base/configmap.yaml"
            sh "kubectl apply -f k8s/base/deployment.yaml"
            sh "kubectl apply -f k8s/base/service.yaml"
            
            echo '--- Forcing Automated Sync ---'
            // Restart pods to pick up the 'ticket-app:latest' image we just built
            sh "kubectl rollout restart deployment/ticket-app -n ticket-app-ns"
            sh "kubectl rollout status deployment/ticket-app -n ticket-app-ns"
        }
    } 
 }
 }

    post {
        always {
            echo 'Pipeline Execution Finished'
        }
    }
}